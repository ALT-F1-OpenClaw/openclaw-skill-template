# {{Skill Name}} Configuration
# Copy to .env and fill in your values

# ─── Required ────────────────────────────────────────────────────────────────

# Service instance URL (cloud or self-hosted)
SKILL_HOST=

# API token / key
SKILL_API_TOKEN=

# ─── Optional ────────────────────────────────────────────────────────────────

# Default project/workspace identifier
# SKILL_DEFAULT_PROJECT=

# Max results per query (default: 50)
# SKILL_MAX_RESULTS=50

# Max file upload size in bytes (default: 50 MB)
# SKILL_MAX_FILE_SIZE=52428800
